rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return true; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'excerpt', 'date', 'imageUrl', 'category']) &&
             data.title is string && data.title.size() <= 200 &&
             data.excerpt is string && data.excerpt.size() <= 2000 &&
             data.date is string && data.date.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 1048000 &&
             data.category is string && data.category.size() <= 100 &&
             (!data.keys().contains('content') || data.content is string) &&
             (!data.keys().contains('authorName') || data.authorName is string) &&
             (!data.keys().contains('authorRole') || data.authorRole is string) &&
             (!data.keys().contains('authorAvatar') || data.authorAvatar is string) &&
             (!data.keys().contains('likes') || data.likes is number) &&
             (!data.keys().contains('views') || data.views is number);
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['title', 'location', 'date', 'imageUrl']) &&
             data.keys().size() == 4 &&
             data.title is string && data.title.size() <= 200 &&
             data.location is string && data.location.size() <= 200 &&
             data.date is string && data.date.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 1048000;
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['name', 'memberCount']) &&
             data.keys().size() == 2 &&
             data.name is string && data.name.size() <= 200 &&
             data.memberCount is number;
    }

    function isValidCommittee(data) {
      return data.keys().hasAll(['name', 'role', 'description', 'imageUrl', 'displayOrder']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() <= 200 &&
             data.role is string && data.role.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.imageUrl is string && data.imageUrl.size() <= 1048000 &&
             data.displayOrder is number;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(postId) && isValidPost(incoming());
      allow update: if (
        isValidId(postId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'views']) &&
        (!incoming().keys().contains('likes') || incoming().likes is number) &&
        (!incoming().keys().contains('views') || incoming().views is number)
      ) || (
        isAdmin() && isValidId(postId) && isValidPost(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'excerpt', 'date', 'imageUrl', 'category', 'content', 'authorName', 'authorRole', 'authorAvatar', 'likes', 'views'])
        )
      );
      allow delete: if isAdmin() && isValidId(postId);
    }

    match /activities/{activityId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(activityId) && isValidActivity(incoming());
      allow update: if isAdmin() && isValidId(activityId) && isValidActivity(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'location', 'date', 'imageUrl'])
      );
      allow delete: if isAdmin() && isValidId(activityId);
    }

    match /chapters/{chapterId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(chapterId) && isValidChapter(incoming());
      allow update: if isAdmin() && isValidId(chapterId) && isValidChapter(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'memberCount'])
      );
      allow delete: if isAdmin() && isValidId(chapterId);
    }

    match /committee/{memberId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(memberId) && isValidCommittee(incoming());
      allow update: if isAdmin() && isValidId(memberId) && isValidCommittee(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'description', 'imageUrl', 'displayOrder'])
      );
      allow delete: if isAdmin() && isValidId(memberId);
    }
    
    match /memberProfiles/{memberId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /calendarEvents/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if true;
    }
    
    function isValidHero(data) {
      return data.keys().hasAll(['title', 'subtitle', 'description', 'imageUrl']) &&
             data.title is string && 
             data.subtitle is string &&
             data.description is string &&
             data.imageUrl is string;
    }

    function isValidAbout(data) {
      return data.keys().hasAll(['title', 'description1', 'description2', 'imageUrl', 'statsMembers']) &&
             data.title is string &&
             data.description1 is string &&
             data.description2 is string &&
             data.imageUrl is string &&
             data.statsMembers is string;
    }

    function isValidJoin(data) {
      return data.keys().hasAll(['title', 'description', 'adminWhatsApp', 'imageUrl']) &&
             data.title is string &&
             data.description is string &&
             data.adminWhatsApp is string &&
             data.imageUrl is string;
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['name', 'phone', 'address', 'vehicleType', 'vehicleYear', 'licensePlate', 'createdAt']) &&
             data.name is string &&
             data.phone is string &&
             data.address is string &&
             data.vehicleType is string &&
             data.vehicleYear is string &&
             data.licensePlate is string &&
             data.createdAt is string;
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['isActive', 'title', 'content']) &&
             data.isActive is bool &&
             data.title is string &&
             data.content is string;
    }

    match /settings/hero {
      allow read: if true;
      allow write: if isAdmin() && isValidHero(incoming());
    }
    
    match /settings/about {
      allow read: if true;
      allow write: if isAdmin() && isValidAbout(incoming());
    }

    match /settings/join {
      allow read: if true;
      allow write: if isAdmin() && isValidJoin(incoming());
    }

    match /settings/announcement {
      allow read: if true;
      allow write: if isAdmin() && isValidAnnouncement(incoming());
    }

    match /registrations/{docId} {
      allow read, update, delete: if isAdmin();
      allow create: if isValidRegistration(request.resource.data);
    }
  }
}
